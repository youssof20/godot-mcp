{
  "name": "godot-mcp",
  "version": "0.2.0",
  "description": "Godot 4 MCP server — TypeScript stdio bridge to a Godot editor plugin",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "godot-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test:ping": "node scripts/smoke-ws.mjs godot_ping",
    "test:project": "node scripts/smoke-ws.mjs get_project_info",
    "test:phase3": "node scripts/smoke-phase3.mjs",
    "test:phase4": "node scripts/smoke-phase4.mjs",
    "test:phase5": "node scripts/smoke-phase5.mjs",
    "test:phase6": "node scripts/smoke-phase6.mjs",
    "test:phase7": "node scripts/smoke-phase7.mjs",
    "test:phase8": "node scripts/smoke-phase8.mjs",
    "test:phase9": "node scripts/smoke-phase9.mjs",
    "test:phase10": "node scripts/smoke-phase10.mjs",
    "test:phase11": "node scripts/smoke-phase11.mjs",
    "test:tools": "node scripts/smoke-ws.mjs list_available_tools",
    "test:ci": "npm run build && npm run typecheck"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "ws": "^8.18.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/ws": "^8.18.1",
    "typescript": "^5.8.3"
  }
}
